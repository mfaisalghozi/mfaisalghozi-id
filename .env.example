# Notion integration — required for live blog and projects data.
# Without these, the app falls back to hardcoded sample data.
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PROJECTS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ISR webhook secret — used by the /api/revalidate endpoint.
# Set this in Vercel environment variables and in your Notion automation webhook.
# Generate a strong random string, e.g.: openssl rand -hex 32
REVALIDATE_SECRET=your-strong-random-secret-here
